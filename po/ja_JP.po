#~ msgstr "選択したバージョン："

#~ msgid "Warning: Capture may not work correctly if version does not match."
#~ msgstr ""
#~ "警告： バージョンが一致しない場合、キャプチャが正しく動作しない可能性があ"
#~ "ります。"

