#~ msgstr "インデックスを入力してください"

#~ msgid "Could not parse input, trying again"
#~ msgstr "入力を解析できませんでした。再試行してください"

#~ msgid "Index out of range, trying again"
#~ msgstr "インデックスが範囲外です。再試行してください"

